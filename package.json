{
  "name": "@canvasa/sdk",
  "version": "0.1.0-alpha.11",
  "description": "Canvas A SDK \u2014 embeddable web components for the AI Tutor. Drop a script tag, get <canvasa-tutor>, <canvasa-chalkboard>, etc. in any host (React, Vue, vanilla, any framework).",
  "main": "./dist/canvasa-sdk.js",
  "scripts": {
    "dev": "vite build --watch",
    "build": "tsc -p tsconfig.build.json && vite build",
    "typecheck": "tsc --noEmit",
    "lint": "tsc --noEmit",
    "preview": "vite preview"
  },
  "keywords": [
    "canvas-a",
    "ai-tutor",
    "physics",
    "embeddable",
    "web-components",
    "custom-elements"
  ],
  "author": "",
  "license": "UNLICENSED",
  "type": "module",
  "module": "./dist/canvasa-sdk.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/canvasa-sdk.js"
    },
    "./styles.css": "./dist/canvasa-sdk.css"
  },
  "files": [
    "dist",
    "src",
    "README.md"
  ],
  "private": false,
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mukesh-bansal/canvasa-sdk.git"
  },
  "devDependencies": {
    "typescript": "^5.4.0",
    "vite": "^5.4.0"
  }
}
